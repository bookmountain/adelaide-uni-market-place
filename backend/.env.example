POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=marketplace

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

ASPNETCORE_ENVIRONMENT=Development
AUTH_APP_JWT_ISSUER=http://localhost
AUTH_APP_JWT_SIGNING_KEY=local-development-signing-key-change-me
AUTH_ALLOWED_EMAIL_DOMAIN=adelaide.edu.au
AUTH_ACTIVATION_BASE_URL=http://localhost:8080/api/auth/activate

